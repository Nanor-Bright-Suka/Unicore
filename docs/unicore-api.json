{"openapi":"3.1.0","info":{"title":"UniCore","description":"UniCore is a backend API implemented in Java Spring Boot for managing university operations. It provides RESTful endpoints for courses, assignments, assignment submissions, and course materials, enforcing academic workflows, student enrollments, and role-based access control (RBAC) for students, lecturers, and admins. Authentication and authorization are fully secured with JWTs, and test cases cover all authentication flows to ensure proper access control and system integrity.The project is containerized using Docker with multi-stage builds, and a CI/CD pipeline ensures automated testing and safe deployment to staging and production environments.","version":"1.0"},"servers":[{"url":"http://localhost:8080","description":"Generated server url"}],"tags":[{"name":"PROFILE","description":"Endpoints for managing user profiles"},{"name":"ROLE AND PERMISSION ASSIGNMENT","description":"Endpoints for assigning roles and permissions to users"},{"name":"ASSIGNMENT SUBMISSION","description":"Endpoints for submitting and grading assignments"},{"name":"COURSE ENROLLMENT","description":"Endpoint for managing enrolled students in courses"},{"name":"AUTHENTICATION","description":"Endpoints for user authentication"},{"name":"ACCOUNT","description":"Endpoints for managing user accounts, such as viewing account details and changing passwords."},{"name":"COURSE","description":"Endpoints for managing courses"},{"name":"ASSIGNMENT","description":"Endpoints for managing assignments"},{"name":"COURSE MATERIAL","description":"Endpoints for managing course materials"}],"paths":{"/api/v1/profile":{"get":{"tags":["PROFILE"],"summary":"Get My Profile","description":"Retrieves the profile information of the currently authenticated user. Requires 'PROFILE_VIEW' authority.","operationId":"getMyProfile","responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseProfileResponseDto"}}}}}},"put":{"tags":["PROFILE"],"summary":"Update My Profile","description":"Updates the profile information of the currently authenticated user. Requires 'PROFILE_UPDATE' authority. Accepts a ProfileUpdateDto in the request body and returns a success message upon successful update.","operationId":"updateMyProfile","parameters":[{"name":"dto","in":"query","required":true,"schema":{"$ref":"#/components/schemas/ProfileUpdateDto"}},{"name":"file","in":"query","required":true,"schema":{"type":"string","format":"binary"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseVoid"}}}}}}},"/api/v1/course/{courseId}":{"get":{"tags":["COURSE"],"summary":"View Course","description":"View course for the  currently authenticated user. Requires 'COURSE_VIEW' authority.","operationId":"getCourseById","parameters":[{"name":"courseId","in":"path","required":true,"schema":{"type":"string","format":"uuid"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseCourseResponseDto"}}}}}},"put":{"tags":["COURSE"],"summary":"Update Course","description":"Update course of the  currently authenticated user. Requires 'COURSE_UPDATE' authority.","operationId":"updateCourse","parameters":[{"name":"courseId","in":"path","required":true,"schema":{"type":"string","format":"uuid"}}],"requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/CourseUpdateRequestDto"}}},"required":true},"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseCourseResponseDto"}}}}}}},"/api/v1/course-materials/courses/{courseId}/materials/{materialId}":{"put":{"tags":["COURSE MATERIAL"],"summary":"Update Course Material","description":"Allows a lecturer to update an existing course material. Supports updating the title, description, file (PDF/DOCX), or video link. Requires 'COURSE_MATERIAL_UPDATE' authority.","operationId":"updateMaterial","parameters":[{"name":"courseId","in":"path","required":true,"schema":{"type":"string","format":"uuid"}},{"name":"materialId","in":"path","required":true,"schema":{"type":"string","format":"uuid"}},{"name":"EditRequest","in":"query","required":true,"schema":{"$ref":"#/components/schemas/CreateAndUpdateRequestDto"}}],"requestBody":{"content":{"application/json":{"schema":{"type":"object","properties":{"file":{"type":"string","format":"binary"}}}}}},"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseMaterialResponseDto"}}}}}}},"/api/v1/assignment/{assignmentId}":{"get":{"tags":["ASSIGNMENT"],"summary":"View Assignment","description":"Retrieves details of a single assignment by ID. Requires 'ASSIGNMENT_VIEW' authority. Returns an AssignmentResponse.","operationId":"getAssignment","parameters":[{"name":"assignmentId","in":"path","required":true,"schema":{"type":"string","format":"uuid"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseAssignmentResponseDto"}}}}}},"put":{"tags":["ASSIGNMENT"],"summary":"Update Assignment","description":"Allows a lecturer to update an existing assignment in DRAFT or PUBLISHED state. Requires 'ASSIGNMENT_UPDATE' authority. Returns the updated AssignmentResponse.","operationId":"updateAssignment","parameters":[{"name":"assignmentId","in":"path","required":true,"schema":{"type":"string","format":"uuid"}}],"requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/AssignmentUpdateRequestDto"}}},"required":true},"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseAssignmentResponseDto"}}}}}}},"/api/v1/course":{"post":{"tags":["COURSE"],"summary":"Create Course","description":"Create course of the  currently authenticated user. Requires 'COURSE_CREATE' authority.","operationId":"createCourse","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/CourseCreateRequestDto"}}},"required":true},"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseCourseResponseDto"}}}}}}},"/api/v1/course-materials/{courseId}":{"post":{"tags":["COURSE MATERIAL"],"summary":"Create Course Material","description":"Allows a lecturer to upload a course material (PDF or DOCX) or provide a video link for a published course. Requires 'COURSE_MATERIAL_CREATE' authority.","operationId":"createMaterial","parameters":[{"name":"courseId","in":"path","required":true,"schema":{"type":"string","format":"uuid"}},{"name":"request","in":"query","required":true,"schema":{"$ref":"#/components/schemas/CreateAndUpdateRequestDto"}}],"requestBody":{"content":{"application/json":{"schema":{"type":"object","properties":{"file":{"type":"string","format":"binary"}}}}}},"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseMaterialResponseDto"}}}}}}},"/api/v1/course-enrollment/{courseId}/enroll":{"post":{"tags":["COURSE ENROLLMENT"],"summary":"Enroll in a course","description":"Allows a student to enroll in a course. Requires 'COURSE_ENROLLMENT' authority.","operationId":"enrollStudent","parameters":[{"name":"courseId","in":"path","required":true,"schema":{"type":"string","format":"uuid"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseEnrollmentResponseDto"}}}}}}},"/api/v1/auth/register":{"post":{"tags":["AUTHENTICATION"],"summary":"Register user","description":"Registers a new user with the provided details. Returns a success message upon successful registration.","operationId":"registerUser","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/UserRegisterDto"}}},"required":true},"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseVoid"}}}}}}},"/api/v1/auth/refresh":{"post":{"tags":["AUTHENTICATION"],"summary":"Refresh token","description":"Refreshes the access token using the refresh token stored in HttpOnly cookie. Returns new access token in response body and new refresh token in HttpOnly cookie","operationId":"refresh","parameters":[{"name":"refreshToken","in":"cookie","required":true,"schema":{"type":"string"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"type":"object","additionalProperties":{"type":"string"}}}}}}}},"/api/v1/auth/logout":{"post":{"tags":["AUTHENTICATION"],"summary":"Logout user","description":"Logs out the user by revoking the refresh token provided in the HttpOnly cookie and deleting the cookie from the client. Returns a success message upon successful logout.","operationId":"logout","parameters":[{"name":"refreshToken","in":"cookie","required":true,"schema":{"type":"string"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseVoid"}}}}}}},"/api/v1/auth/logout-all":{"post":{"tags":["AUTHENTICATION"],"summary":"Logout from all devices","description":"Logs out the user from all devices by revoking all refresh tokens associated with the user's email and deleting the cookie from the client. Returns a success message upon successful logout from all devices.","operationId":"logoutAll","responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseVoid"}}}}}}},"/api/v1/auth/login":{"post":{"tags":["AUTHENTICATION"],"summary":"Login user","description":"Authenticates user and returns access token in response body and refresh token in HttpOnly cookie","operationId":"loginUser","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/UserloginDto"}}},"required":true},"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseLoginResponseDto"}}}}}}},"/api/v1/assignment":{"post":{"tags":["ASSIGNMENT"],"summary":"Create Assignment","description":"Allows a lecturer to create a new assignment in DRAFT state. Requires 'COURSE_CREATE' or 'ASSIGNMENT_CREATE' authority. Returns an AssignmentResponse containing assignment details.","operationId":"createAssignment","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/AssignmentCreateRequestDto"}}},"required":true},"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseAssignmentResponseDto"}}}}}}},"/api/v1/assignment-submission/{assignmentId}":{"post":{"tags":["ASSIGNMENT SUBMISSION"],"summary":"Submit Assignment","description":"Allows a student to submit a PDF file for a published assignment. Requires 'ASSIGNMENT_SUBMIT' authority. Returns the submitted AssignmentSubmissionResponse.","operationId":"submitAssignment","parameters":[{"name":"assignmentId","in":"path","required":true,"schema":{"type":"string","format":"uuid"}},{"name":"studentId","in":"query","required":true,"schema":{"type":"string","format":"uuid"}}],"requestBody":{"content":{"application/json":{"schema":{"type":"object","properties":{"file":{"type":"string","format":"binary"}},"required":["file"]}}}},"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseAssignmentSubmissionResponseDto"}}}}}}},"/api/v1/account/password":{"post":{"tags":["ACCOUNT"],"summary":"Change Password","description":"Allows the currently authenticated user to change their password. Requires 'PASSWORD_CHANGE' authority. Accepts a ChangePasswordRequestDto in the request body containing the old and new passwords, and returns a success message upon successful password change.","operationId":"changePassword","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/ChangePasswordRequestDto"}}},"required":true},"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseVoid"}}}}}}},"/api/v1/course/{courseId}/start":{"patch":{"tags":["COURSE"],"summary":"Start Course","description":"Start course for the  currently authenticated user. Requires 'COURSE_START' authority.","operationId":"startCourse","parameters":[{"name":"courseId","in":"path","required":true,"schema":{"type":"string","format":"uuid"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseCourseResponseDto"}}}}}}},"/api/v1/course/{courseId}/publish":{"patch":{"tags":["COURSE"],"summary":"Publish Course","description":"Publish course of the  currently authenticated user. Requires 'COURSE_PUBLISH' authority.","operationId":"publishCourse","parameters":[{"name":"courseId","in":"path","required":true,"schema":{"type":"string","format":"uuid"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseCourseResponseDto"}}}}}}},"/api/v1/course/{courseId}/open-enrollment":{"patch":{"tags":["COURSE"],"summary":"Open Course Enrollment","description":"Open course enrollment of the  currently authenticated user. Requires 'COURSE_OPEN_ENROLLMENT' authority.","operationId":"openEnrollment","parameters":[{"name":"courseId","in":"path","required":true,"schema":{"type":"string","format":"uuid"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseCourseResponseDto"}}}}}}},"/api/v1/course/{courseId}/complete":{"patch":{"tags":["COURSE"],"summary":"Complete Course","description":"Complete course for the  currently authenticated user. Requires 'COURSE_COMPLETE' authority.","operationId":"completeCourse","parameters":[{"name":"courseId","in":"path","required":true,"schema":{"type":"string","format":"uuid"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseCourseResponseDto"}}}}}}},"/api/v1/course/{courseId}/close-enrollment":{"patch":{"tags":["COURSE"],"summary":"Close Course Enrollment","description":"Close course enrollment of the  currently authenticated user. Requires 'COURSE_CLOSE_ENROLLMENT' authority.","operationId":"closeEnrollment","parameters":[{"name":"courseId","in":"path","required":true,"schema":{"type":"string","format":"uuid"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseCourseResponseDto"}}}}}}},"/api/v1/course/{courseId}/archive":{"patch":{"tags":["COURSE"],"summary":"Archive Course","description":"Archive course for the  currently authenticated user. Requires 'COURSE_ARCHIVE' authority.","operationId":"archiveCourse","parameters":[{"name":"courseId","in":"path","required":true,"schema":{"type":"string","format":"uuid"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseCourseResponseDto"}}}}}}},"/api/v1/assignment/{assignmentId}/start-grade":{"patch":{"tags":["ASSIGNMENT"],"summary":"Start Grading Assignment","description":"Allows a lecturer to start grading an assignment after submissions are closed. Requires 'ASSIGNMENT_START_GRADING' authority. Returns the updated AssignmentResponse with state GRADING_IN_PROGRESS.","operationId":"startGrading","parameters":[{"name":"assignmentId","in":"path","required":true,"schema":{"type":"string","format":"uuid"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseAssignmentResponseDto"}}}}}}},"/api/v1/assignment/{assignmentId}/publish":{"patch":{"tags":["ASSIGNMENT"],"summary":"Publish Assignment","description":"Allows a lecturer to publish a DRAFT assignment, making it available for students to submit. Requires 'ASSIGNMENT_PUBLISH' authority. Returns the updated AssignmentResponse with state PUBLISHED.","operationId":"publishAssignment","parameters":[{"name":"assignmentId","in":"path","required":true,"schema":{"type":"string","format":"uuid"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseAssignmentResponseDto"}}}}}}},"/api/v1/assignment/{assignmentId}/mark-graded":{"patch":{"tags":["ASSIGNMENT"],"summary":"Mark Assignment Graded","description":"Allows a lecturer to mark an assignment as graded after completing grading. Requires 'ASSIGNMENT_MARK_GRADED' authority. Returns the updated AssignmentResponse with state GRADED.","operationId":"markGraded","parameters":[{"name":"assignmentId","in":"path","required":true,"schema":{"type":"string","format":"uuid"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseAssignmentResponseDto"}}}}}}},"/api/v1/assignment/{assignmentId}/close":{"patch":{"tags":["ASSIGNMENT"],"summary":"Close Assignment Submissions","description":"Allows a lecturer to close submissions for a PUBLISHED assignment. Requires 'ASSIGNMENT_SUBMISSION_CLOSE' authority. Returns the updated AssignmentResponse with submissions closed.","operationId":"closeSubmissions","parameters":[{"name":"assignmentId","in":"path","required":true,"schema":{"type":"string","format":"uuid"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseAssignmentResponseDto"}}}}}}},"/api/v1/assignment/{assignmentId}/archive":{"patch":{"tags":["ASSIGNMENT"],"summary":"Archive Assignment","description":"Allows a lecturer to archive a graded assignment. Requires 'ASSIGNMENT_ARCHIVE' authority. Returns the updated AssignmentResponse with state ARCHIVED.","operationId":"archiveAssignment","parameters":[{"name":"assignmentId","in":"path","required":true,"schema":{"type":"string","format":"uuid"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseAssignmentResponseDto"}}}}}}},"/api/v1/assignment-submission/{submissionId}":{"get":{"tags":["ASSIGNMENT SUBMISSION"],"summary":"View Submission","description":"Retrieves a single assignment submission by ID. Requires 'ASSIGNMENT_SUBMISSION_VIEW' authority. Returns the AssignmentSubmissionResponse.","operationId":"getSubmission","parameters":[{"name":"submissionId","in":"path","required":true,"schema":{"type":"string","format":"uuid"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseAssignmentSubmissionResponseDto"}}}}}},"patch":{"tags":["ASSIGNMENT SUBMISSION"],"summary":"Grade Assignment Submission","description":"Allows a lecturer to grade a student's submission. Requires 'ASSIGNMENT_GRADE' authority. Returns the updated AssignmentSubmissionResponse.","operationId":"gradeSubmission","parameters":[{"name":"submissionId","in":"path","required":true,"schema":{"type":"string","format":"uuid"}},{"name":"marks","in":"query","required":true,"schema":{"type":"integer","format":"int32"}},{"name":"feedback","in":"query","required":false,"schema":{"type":"string"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseAssignmentSubmissionResponseDto"}}}}}}},"/api/v1/admin/role":{"patch":{"tags":["ROLE AND PERMISSION ASSIGNMENT"],"summary":"Assign Role to User","description":"Assign Role for  currently authenticated user. Requires 'ROLE_ASSIGN' authority.","operationId":"assignRoleToUser","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/AssignRoleRequestDto"}}},"required":true},"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseRolePermissionResponseDto"}}}}}}},"/api/v1/admin/permission":{"patch":{"tags":["ROLE AND PERMISSION ASSIGNMENT"],"summary":"Assign Permission  to Role","description":"Assign Permission to Role for  currently authenticated user. Requires 'PERMISSION_ASSIGN' authority.","operationId":"assignPermissionsToRole","requestBody":{"content":{"application/json":{"schema":{"$ref":"#/components/schemas/AssignPermissionRequestDto"}}},"required":true},"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseRolePermissionResponseDto"}}}}}}},"/api/v1/course/courses":{"get":{"tags":["COURSE"],"summary":"View All Courses","description":"View all courses for the  currently authenticated user. Requires 'COURSE_VIEW_ALL' authority.","operationId":"getAllCourses","responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseListCourseResponseDto"}}}}}}},"/api/v1/course-materials/{materialId}":{"get":{"tags":["COURSE MATERIAL"],"summary":"Get Course Material","description":"Returns details of a specific course material. Only enrolled students or the course lecturer can access this material.","operationId":"getMaterial","parameters":[{"name":"materialId","in":"path","required":true,"schema":{"type":"string","format":"uuid"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseMaterialResponseDto"}}}}}},"delete":{"tags":["COURSE MATERIAL"],"summary":"Delete Course Material","description":"Allows a lecturer to delete a course material. Requires 'COURSE_MATERIAL_DELETE' authority.","operationId":"deleteMaterial","parameters":[{"name":"materialId","in":"path","required":true,"schema":{"type":"string","format":"uuid"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseVoid"}}}}}}},"/api/v1/course-materials/{materialId}/download":{"get":{"tags":["COURSE MATERIAL"],"summary":"Download Course Material","description":"Downloads the file for a specific course material. Only enrolled students or the course lecturer can access this material.","operationId":"downloadMaterial","parameters":[{"name":"materialId","in":"path","required":true,"schema":{"type":"string","format":"uuid"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"type":"string","format":"binary"}}}}}}},"/api/v1/course-materials/course/{courseId}/materials":{"get":{"tags":["COURSE MATERIAL"],"summary":"Get Course Materials","description":"Returns all materials for a course. Only enrolled students or the course lecturer can access these materials.","operationId":"getMaterialsByCourse","parameters":[{"name":"courseId","in":"path","required":true,"schema":{"type":"string","format":"uuid"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseListMaterialResponseDto"}}}}}}},"/api/v1/course-enrollment/{courseId}":{"get":{"tags":["COURSE ENROLLMENT"],"summary":"Get enrolled students list","description":"Return a list of students currently enrolled in the specified course. Requires 'COURSE_ENROL_LIST' authority. Each student is represented by an EnrollmentResponseDto containing their userId, name, and email.","operationId":"getEnrolledStudents","parameters":[{"name":"courseId","in":"path","required":true,"schema":{"type":"string","format":"uuid"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseListEnrollmentResponseDto"}}}}}}},"/api/v1/course-enrollment/{courseId}/enrolled-count":{"get":{"tags":["COURSE ENROLLMENT"],"summary":"Get enrolled students count","description":"Returns the total number of students currently enrolled in the specified course. Requires 'COURSE_ENROL_COUNT' authority.","operationId":"getEnrolledCount","parameters":[{"name":"courseId","in":"path","required":true,"schema":{"type":"string","format":"uuid"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseLong"}}}}}}},"/api/v1/auth/health":{"get":{"tags":["AUTHENTICATION"],"summary":"Health Check","description":"Endpoint to check if the authentication system is running. Returns a simple greeting message.","operationId":"health","responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"type":"string"}}}}}}},"/api/v1/assignment-submission/assignments/{assignmentId}":{"get":{"tags":["ASSIGNMENT SUBMISSION"],"summary":"View All Submissions for Assignment","description":"Retrieves all submissions for a specific assignment. Requires 'ASSIGNMENT_SUBMISSION_VIEW' authority. Returns a list of AssignmentSubmissionResponse.","operationId":"getSubmissionsForAssignment","parameters":[{"name":"assignmentId","in":"path","required":true,"schema":{"type":"string","format":"uuid"}}],"responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseListAssignmentSubmissionResponseDto"}}}}}}},"/api/v1/account":{"get":{"tags":["ACCOUNT"],"summary":"Get My Account","description":"Retrieves the account details of the currently authenticated user. Requires 'ACCOUNT_VIEW' authority. Returns an AccountResponseDto containing the user's account information.","operationId":"getMyAccount","responses":{"200":{"description":"OK","content":{"*/*":{"schema":{"$ref":"#/components/schemas/ApiResponseAccountResponseDto"}}}}}}}},"components":{"schemas":{"ProfileUpdateDto":{"type":"object","properties":{"firstName":{"type":"string","description":"User first name","example":"John","maxLength":50,"minLength":2},"lastName":{"type":"string","description":"User last name","example":"Doe","maxLength":50,"minLength":2},"bio":{"type":"string","description":"User bio","example":"Software developer with a passion for open-source projects.","maxLength":500,"minLength":0},"imageUrl":{"type":"string","description":"User profile picture URL (allowed formats: png, jpg, jpeg)","example":"https://example.com/profile.png","maxLength":255,"minLength":0}},"required":["firstName","lastName"]},"ApiResponseVoid":{"type":"object","properties":{"success":{"type":"boolean"},"message":{"type":"string"},"data":{}}},"CourseUpdateRequestDto":{"type":"object","properties":{"title":{"type":"string","description":"Course title, e.g., Data Structures","example":"Data Structures","maxLength":100,"minLength":2},"description":{"type":"string","description":"Optional description of the course","example":"Introduction to basic data structures","maxLength":2000,"minLength":0},"semester":{"type":"string","description":"Semester in which the course is offered","enum":["FIRST","SECOND"],"example":"FALL"},"academicYear":{"type":"string","description":"Academic year of the course, e.g., 2025/2026","example":"2025/2026","maxLength":9,"minLength":7},"maxCapacity":{"type":"integer","format":"int32","description":"Maximum number of students allowed","example":50}},"required":["academicYear","semester","title"]},"ApiResponseCourseResponseDto":{"type":"object","properties":{"success":{"type":"boolean"},"message":{"type":"string"},"data":{"$ref":"#/components/schemas/CourseResponseDto"}}},"CourseResponseDto":{"type":"object","properties":{"id":{"type":"string","format":"uuid"},"code":{"type":"string"},"title":{"type":"string"},"description":{"type":"string"},"state":{"type":"string","enum":["CREATED","PUBLISHED","ENROLLMENT_OPEN","ENROLLMENT_CLOSED","ACTIVE","COMPLETED","ARCHIVED"]},"semester":{"type":"string","enum":["FIRST","SECOND"]},"academicYear":{"type":"string"},"maxCapacity":{"type":"integer","format":"int32"},"lecturerId":{"type":"string"},"createdAt":{"type":"string","format":"date-time"},"updatedAt":{"type":"string","format":"date-time"}}},"CreateAndUpdateRequestDto":{"type":"object","properties":{"title":{"type":"string","description":"Title of the course material","example":"Week 1 Lecture Notes","maxLength":150,"minLength":2},"description":{"type":"string","description":"Optional description of the material","example":"Introduction to basic programming concepts","maxLength":2000,"minLength":0},"materialType":{"type":"string","description":"Type of material being uploaded","enum":["FILE","VIDEO_LINK"],"example":"FILE"},"videoUrl":{"type":"string","description":"External video URL (required if materialType = VIDEO_LINK)","example":"https://www.youtube.com/watch?v=example"}},"required":["materialType","title"]},"ApiResponseMaterialResponseDto":{"type":"object","properties":{"success":{"type":"bo